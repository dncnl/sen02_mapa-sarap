{
  "version": 2,
  "buildCommand": "npm run build || true",
  "outputDirectory": ".",
  "regions": ["sin1"],
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/admin/places/:id", "destination": "/api/admin/places.js?id=:id" },
    { "source": "/api/admin/dishes/:id", "destination": "/api/admin/dishes.js?id=:id" },
    { "source": "/api/admin/amenities/:id", "destination": "/api/admin/amenities.js?id=:id" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/admin", "destination": "/src/pages/admin/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}